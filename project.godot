; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="2D guno game template"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GravityManager="*res://scripts/managers/gravity_manager.gd"
DebugWarp="*res://scripts/managers/debug_warp.gd"
Audio="*res://scripts/managers/audio.gd"
BeatClock="*res://scripts/managers/beat_clock.gd"
WeaponProgress="*res://scripts/managers/weapon_progress.gd"
Juice="*res://scripts/managers/juice.gd"
GameStats="*res://scripts/managers/gamestats.gd"
Transitions="*res://scripts/managers/transitions.gd"

[display]

window/size/viewport_width=1280.0
window/size/viewport_height=720.0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="2D guno game template"

